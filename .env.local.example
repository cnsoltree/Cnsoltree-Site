# ============================================================
# Site URL（影响 canonical / OG / sitemap / schema 等所有绝对 URL）
# 本地开发可以保持这个值；生产环境必须在 Vercel 后台单独设置
# ============================================================
NEXT_PUBLIC_APP_URL=https://www.elesoltree.com

# ============================================================
# Supabase
# 在 https://supabase.com/dashboard 项目设置中获取
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================================
# Resend（邮件发送）
# 在 https://resend.com/api-keys 获取
# ============================================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ============================================================
# Cloudflare R2（对象存储）
# 在 Cloudflare Dashboard -> R2 -> Manage API tokens 获取
# ============================================================
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
